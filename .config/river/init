#!/bin/sh

# River startup converted from ~/.config/hypr/hyprland.conf.
# This file is intentionally separate from ~/.config/river/init.

export XCURSOR_SIZE=24
export QT_QPA_PLATFORMTHEME=qt6ct
export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=river
export XDG_SESSION_DESKTOP=river

# Keep D-Bus/systemd aware of the Wayland session, matching the Hyprland config.
dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP

# Hyprland monitor conversion:
# monitor=DP-1,2560x1440@360,0x0,1
# monitor=DP-3,2560x1440@165,-1440x-640,1,transform,1
# rrwm owns output layout, so see rrwm.hypr-converted.toml for output settings.

# Launch rrwm. rrwm currently reads ~/.config/river/rrwm.toml and has no config-path flag.
rrwm &

# Startup commands converted from Hyprland exec-once.
systemctl --user start plasma-polkit-agent &
waybar &
hyprpaper &
mako &
hypridle &
xrandr --output DP-2 --primary &
