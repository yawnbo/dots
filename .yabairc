#!/bin/sh

YABAI=/opt/homebrew/bin/yabai
LOAD_SA="/usr/bin/sudo $YABAI --load-sa"

# The scripting addition is unloaded whenever Dock restarts.
$YABAI -m signal --add event=dock_did_restart action="$LOAD_SA"
$LOAD_SA

$YABAI -m config                              \
    external_bar                main:0:0     \
    layout                      bsp           \
    window_placement            second_child  \
    split_ratio                 0.50          \
    split_type                  auto          \
    auto_balance                off           \
    mouse_follows_focus         on            \
    focus_follows_mouse         autoraise     \
    mouse_modifier              fn            \
    mouse_action1               move          \
    mouse_action2               resize        \
    mouse_drop_action           swap          \
    window_animation_duration   0.0           \
    window_opacity_duration     0.0           \
    active_window_opacity       1.0           \
    normal_window_opacity       0.75          \
    window_opacity              on            \
    insert_feedback_color       0xaad75f5f    \
    top_padding                 0             \
    left_padding                0             \
    right_padding               0             \
    bottom_padding              0             \
    window_shadow               off           \
    window_gap                  0

echo "yabai configuration loaded."
